generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  BUYER
  AGENT
  LANDLORD
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
  EXPIRED
}

enum Purpose {
  RENT
  SALE
}

enum PropertyType {
  APARTMENT
  DUPLEX
  STUDIO
  SHORT_LET
  LAND
  COMMERCIAL
  TERRACE
}

enum FurnishingStatus {
  FURNISHED
  SEMI_FURNISHED
  UNFURNISHED
}

enum AvailabilityStatus {
  AVAILABLE_NOW
  COMING_SOON
  OCCUPIED
}

enum LeadStatus {
  NEW
  CONTACTED
  INSPECTION_SCHEDULED
  NEGOTIATION
  CLOSED
  LOST
}

enum BookingStatus {
  PENDING
  APPROVED
  RESCHEDULED
  REJECTED
  COMPLETED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum VerificationType {
  AGENT_LICENSE
  IDENTITY
  LANDLORD_PROOF
}

enum ReportStatus {
  NEW
  REVIEWING
  RESOLVED
}

enum NotificationType {
  MESSAGE
  INQUIRY
  BOOKING
  VERIFICATION
  LISTING
  SUBSCRIPTION
}

model User {
  id                  String                @id @default(cuid())
  fullName            String
  email               String                @unique
  passwordHash        String
  phone               String?
  role                Role
  avatar              String?
  isEmailVerified     Boolean               @default(false)
  isPhoneVerified     Boolean               @default(false)
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  profile             UserProfile?
  createdProperties   Property[]            @relation("PropertyCreator")
  assignedProperties  Property[]            @relation("AssignedAgent")
  landlordProperties  Property[]            @relation("LandlordProperty")
  approvedProperties  Property[]            @relation("ApprovedListing")
  buyerInquiries      Inquiry[]             @relation("InquiryBuyer")
  agentInquiries      Inquiry[]             @relation("InquiryAgent")
  landlordInquiries   Inquiry[]             @relation("InquiryLandlord")
  sentMessages        Message[]
  requestedBookings   ViewingBooking[]      @relation("BookingRequester")
  agentBookings       ViewingBooking[]      @relation("BookingAgent")
  subscriptions       UserSubscription[]
  verificationRequests VerificationRequest[]
  reportedItems       Report[]              @relation("Reporter")
  reportsAgainst      Report[]              @relation("ReportedUser")
  notifications       Notification[]
  favorites           Favorite[]
  compareItems        CompareItem[]
}

model UserProfile {
  userId              String             @id
  bio                 String?
  location            String?
  preferences         String[]
  companyName         String?
  licenseNumber       String?
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  trustScore          Int                @default(0)
  whatsappNumber      String?
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id                  String              @id @default(cuid())
  title               String
  slug                String              @unique
  description         String
  purpose             Purpose
  propertyType        PropertyType
  price               Decimal             @db.Decimal(14, 2)
  currency            String              @default("NGN")
  bedrooms            Int
  bathrooms           Int
  toilets             Int?
  size                Int
  furnishingStatus    FurnishingStatus
  availabilityStatus  AvailabilityStatus
  address             String
  city                String
  state               String
  area                String
  neighborhood        String?
  latitude            Float
  longitude           Float
  amenities           String[]
  featured            Boolean             @default(false)
  reviewedListing     Boolean             @default(false)
  status              ListingStatus       @default(DRAFT)
  createdByUserId     String
  assignedAgentId     String?
  landlordId          String?
  approvedByAdminId   String?
  yearBuilt           Int?
  reference           String              @unique
  serviceCharge       Decimal?            @db.Decimal(14, 2)
  cautionFee          Decimal?            @db.Decimal(14, 2)
  agencyFee           Decimal?            @db.Decimal(14, 2)
  legalFee            Decimal?            @db.Decimal(14, 2)
  commissionFee       Decimal?            @db.Decimal(14, 2)
  isPetFriendly       Boolean             @default(false)
  parkingSpaces       Int                 @default(0)
  availableFrom       DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  expiresAt           DateTime?
  createdBy           User                @relation("PropertyCreator", fields: [createdByUserId], references: [id])
  assignedAgent       User?               @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  landlord            User?               @relation("LandlordProperty", fields: [landlordId], references: [id])
  approvedByAdmin     User?               @relation("ApprovedListing", fields: [approvedByAdminId], references: [id])
  images              PropertyImage[]
  inquiries           Inquiry[]
  threads             MessageThread[]
  bookings            ViewingBooking[]
  reports             Report[]
  favorites           Favorite[]
  compareItems        CompareItem[]

  @@index([city, state, area])
  @@index([purpose])
  @@index([propertyType])
  @@index([price])
  @@index([status])
  @@index([featured])
  @@index([createdAt])
  @@index([assignedAgentId])
}

model PropertyImage {
  id        String   @id @default(cuid())
  propertyId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id         String     @id @default(cuid())
  propertyId String
  buyerId    String
  agentId    String
  landlordId String?
  message    String
  status     LeadStatus @default(NEW)
  source     String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer      User       @relation("InquiryBuyer", fields: [buyerId], references: [id])
  agent      User       @relation("InquiryAgent", fields: [agentId], references: [id])
  landlord   User?      @relation("InquiryLandlord", fields: [landlordId], references: [id])
}

model MessageThread {
  id          String    @id @default(cuid())
  propertyId  String?
  subject     String?
  participantIds String[]
  createdAt   DateTime  @default(now())
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  messages    Message[]
}

model Message {
  id         String        @id @default(cuid())
  threadId    String
  senderId    String
  body       String
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender     User          @relation(fields: [senderId], references: [id])
}

model ViewingBooking {
  id          String        @id @default(cuid())
  propertyId   String
  requesterId  String
  agentId      String
  scheduledAt  DateTime
  status      BookingStatus @default(PENDING)
  note        String?
  createdAt   DateTime      @default(now())
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requester   User          @relation("BookingRequester", fields: [requesterId], references: [id])
  agent       User          @relation("BookingAgent", fields: [agentId], references: [id])
}

model SubscriptionPlan {
  id                    String             @id @default(cuid())
  name                  String
  price                 Decimal            @db.Decimal(14, 2)
  billingInterval       BillingInterval
  listingLimit          Int
  featuredLimit         Int
  analyticsEnabled      Boolean            @default(false)
  prioritySupport       Boolean            @default(false)
  verificationFeeIncluded Boolean         @default(false)
  isActive              Boolean            @default(true)
  subscriptions         UserSubscription[]
}

model UserSubscription {
  id                       String             @id @default(cuid())
  userId                    String
  planId                    String
  status                   SubscriptionStatus @default(ACTIVE)
  startedAt                DateTime           @default(now())
  expiresAt                DateTime
  paymentProviderReference String?
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                     SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model VerificationRequest {
  id          String             @id @default(cuid())
  userId       String
  type        VerificationType
  documentUrls String[]
  status      VerificationStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime           @default(now())
  reviewedAt  DateTime?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id             String       @id @default(cuid())
  reporterId     String
  propertyId     String?
  reportedUserId String?
  reason         String
  details        String
  status         ReportStatus @default(NEW)
  createdAt      DateTime     @default(now())
  reporter       User         @relation("Reporter", fields: [reporterId], references: [id])
  property       Property?    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reportedUser   User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model CompareItem {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}
